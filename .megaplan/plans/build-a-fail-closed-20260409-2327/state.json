  "last_gate": {
    "recommendation": "PROCEED",
    "rationale": "The plan is ready to execute. The weighted score has reached 0, all previously significant blocking flags are resolved, the success criteria now cover the locked user requirements, and preflight remains fully green. The remaining concern is a non-blocking verification gap around automated testing of persistent-view re-registration; that should be handled during implementation and staging validation, not by another planning loop.",
    "signals_assessment": "Score trajectory improved cleanly from 28.5 to 17.75 to 0 across three iterations, with no unresolved significant flags at the gate and no sign of loop churn beyond one recurring note about restart-safe view verification. Preflight posture is fully positive: project directory exists and is writable, success criteria are present, and both backends are available. This is the right point to move from planning into execution.",
    "warnings": [
      "Add implementation-time tests around `PaymentConfirmView` registration and `bot.add_view(...)` recovery if feasible; the current plan relies on manual smoke testing for that restart path.",
      "Watch the known Supabase/RPC debt during rollout, since `claim_due_*` style RPC behavior is still a repo-wide risk area rather than a payment-specific design flaw."
    ],
    "settled_decisions": [
      {
        "id": "decision-test-payment-sol",
        "decision": "Test payments use a fixed global SOL dust amount via `PAYMENT_TEST_AMOUNT_SOL`, not a USD-derived amount.",
        "rationale": "This is user-locked and preserves constant on-chain validation behavior regardless of price."
      },
      {
        "id": "decision-payment-routing",
        "decision": "Payment destinations are resolved through `payment_channel_routes` plus `ServerConfig.resolve_payment_destinations()`, with fallback to the source thread only when no route exists.",
        "rationale": "This satisfies the route-configured destination requirement while preserving a workable default path."
      },
      {
        "id": "decision-fail-closed-hold",
        "decision": "Ambiguous post-submit states and confirmation timeouts go to `manual_hold`, and `release_payment` is the only path out of that state.",
        "rationale": "This is the core fail-closed invariant that prevents unsafe automatic retries after possible submission."
      },
      {
        "id": "decision-retry-boundary",
        "decision": "Direct retry is allowed only from `failed`; `submitted` and `manual_hold` cannot be retried directly.",
        "rationale": "This keeps retry behavior aligned with definitive failure only."
      },
      {
        "id": "decision-producer-handoff",
        "decision": "Terminal payment results are handed back to producers through direct `bot.get_cog()` method calls, with `GrantsCog.handle_payment_result()` as the concrete grants integration.",
        "rationale": "This chooses one repo-native cross-cog pattern and avoids mixed listener/callback/event designs."
      },
      {
        "id": "decision-grants-linkage",
        "decision": "Grants link to payments by `(producer='grants', producer_ref=thread_id, is_test)` rather than a single `payment_ref` column.",
        "rationale": "This cleanly supports separate test and final payment attempts without collapsing them into one pointer."
      }
    ],
